{
  "version": 6,
  "cmakeMinimumRequired": {
    "major": 3,
    "minor": 25,
    "patch": 0
  },
  "configurePresets": [
    {
      "name": "default",
      "hidden": true,
      "generator": "Ninja",
      "binaryDir": "${sourceDir}/build-${presetName}"
    },
    {
      "name": "release",
      "displayName": "Release",
      "description": "Build the full project in Release mode",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "Release"
      }
    },
    {
      "name": "tests",
      "displayName": "Tests",
      "description": "Build tests in RelWithDebInfo mode",
      "inherits": "default",
      "binaryDir": "${sourceDir}/build-tests",
      "cacheVariables": {
        "CMAKE_BUILD_TYPE": "RelWithDebInfo"
      }
    },
    {
      "name": "tests-with-coverage",
      "displayName": "Tests + Coverage",
      "description": "Build tests with GCC/Clang code coverage instrumentation",
      "inherits": "tests",
      "cacheVariables": {
        "ENABLE_COVERAGE": "ON"
      }
    }
  ],
  "buildPresets": [
    {
      "name": "release",
      "configurePreset": "release",
      "configuration": "Release"
    },
    {
      "name": "tests",
      "configurePreset": "tests",
      "configuration": "RelWithDebInfo"
    },
    {
      "name": "tests-with-coverage",
      "configurePreset": "tests-with-coverage",
      "configuration": "RelWithDebInfo"
    }
  ],
  "testPresets": [
    {
      "name": "tests",
      "configurePreset": "tests",
      "output": {
        "outputOnFailure": true
      }
    }
  ]
}